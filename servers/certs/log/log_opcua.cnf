[ req ]
default_bits       = 2048
prompt             = no
default_md         = sha256
distinguished_name = dn
x509_extensions    = v3_req

[ dn ]
C  = KR
O  = OPCUA-DEMO
OU = LOG
CN = LOGServer

[ v3_req ]
basicConstraints = CA:FALSE
keyUsage = critical, digitalSignature, keyEncipherment
extendedKeyUsage = serverAuth, clientAuth
subjectAltName = @alt_names

[ alt_names ]
URI.1 = urn:opcua:log
DNS.1 = localhost
IP.1  = 127.0.0.1
